##### BASH 42 #####

### Editor & Compilation ###
# ccw: Compile with all moulinette flags
alias ccw="cc -Wall -Werror -Wextra"
# ff: Run the norminette
alias ff="norminette"
# v: Open vim
alias v="vim"
# vh: Open vim with header 42
alias vh="vim +Stdheader"
# a: Execute the a.out file
alias a="./a.out"
# p: Execute with python3
alias p="python3"

### Git ###
# gg: Add all the .c file of your directory and sub-directories to git and open a commit message window
alias gg="find . -name '*.c' -exec git add {} ';' && git commit"
# gu: Add all modified files
alias gu="git add -u"
# gs: Run git status
alias gs="git status"
# gpom: Run git push on the main branch
alias gpom="git push origin main"
# gp: Run git push on the actual branch
alias gp="git push"
# gc: Run git clone
alias gc="git clone"
# rv: Checks multiple things to prepare for a review
rv()
{
	git status &>/dev/null
	if [[ $? != 0 ]]; then
		echo "This is not a git repository."
	else
		echo -n "Checking norme..."
		out=$(norminette . | grep Error! | cut -d':' -f 1 | xargs -I{} echo -e "\xe2\x9d\x8c Norminette failed on \e[1;31m"{}"\e[0m")
		echo -ne "\r                 \r"
		if [[ -n $out ]]; then
			echo "$out"
		else
			echo -e "\xe2\x9c\x85 Norminette OK."
		fi
		out=$(find . -type f -not -path '*/.git*' -not -name '*.h' -not -name '*.c' -exec echo -e '\xe2\x9a\xa0\xef\xb8\x8f  Found a file that is not .c or .h: \e[1;31m'{}'\e[0m' \;)
		if [[ -n $out ]]; then
			echo "$out"
		else
			echo -e "\xe2\x9c\x85 No files other than .c and .h"
		fi
		out=$(git ls-files . --exclude-standard --others --modified | xargs -I{} echo -e "\xe2\x9a\xa0\xef\xb8\x8f  File is not committed: \e[1;31m"{}"\e[0m")
		if [[ -n $out ]]; then
			echo -e "$out"
		else
			echo -e "\xe2\x9c\x85 All files already committed. Be sure to check on github.com if you have pushed on the correct repo."
		fi
		echo "Current repository is located at https://github.com/"$(git config --get remote.origin.url | cut -d: -f 2)
	fi
}
# gcd: Git clone and go to the directory created
gcd()
{
	    if [[ $# == 1 ]]; then
                git clone $1 && cd $(basename "$_" .git)
        elif [[ $# == 2 ]]; then
                git clone $1 $2 && cd $2
        elif [[ $# == 0 ]]; then
                echo -e '\033[31mPlease specify a git repository.\033[0m'
        fi
}

### Bash42 ###
## All commands below are used for this project, please do not touch them
unalias help42 2>/dev/null
# help42: Shows this help page
help42()
{
	text="$(grep -B 1 '^### \|^alias\|^\S*(' ~/.bash42 | grep '^#\+' | sed 's/^### /\\033[1;32m/' | sed 's/ ###$/\\033[0m/' | sed 's/^# \(\S\+\):/\\033[1;91m\1\\033[0m:/')"
	echo -e "$text"
}
unalias b42 2>/dev/null
# b42: Update to the latest version
b42()
{
	wget -q https://raw.githubusercontent.com/SaikoroAsh/Bash42/refs/heads/main/.bash42 -O ~/.bash42.tmp 
	if [[ $? == 0 ]]; then
		dif=$(diff ~/.bash42 ~/.bash42.tmp | grep -B 1 '^> alias\|^> \S*(' | grep "^> #" | cut -c5- | sed -E 's/^(\S*):(.*)/New command: '$(echo -e '\033[1;31m')'\1'$(echo -e '\033[0m')':\2/')
		if [[ -n $dif ]]; then
			echo $dif
		else
			echo -e '\033[32mBash42 is already up to date\033[0m'
		fi
		mv ~/.bash42.tmp ~/.bash42 && source ~/.bash42
	fi
}
# sl: Same as ls but if you're not so good with your keyboard
sl()
{
	qr https://github.com/SaikoroAsh/Bash42
	echo "It's always a good time to advertise :)"
	echo "Type better next time"
}
