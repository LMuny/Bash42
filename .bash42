##### BASH 42 #####

### Editor & Compilation ###
alias ccw="cc -Wall -Werror -Wextra"
alias ff="norminette"
alias v="vim"

### Git ###
alias gg="find . -name '*.c' -exec git add {} ';' && git commit"
alias gpom="git push origin main"

### Bash42 ###
alias b42="wget https://raw.githubusercontent.com/SaikoroAsh/Bash42/refs/heads/main/.bash42 -O ~/.bash42"
